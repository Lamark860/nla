JWT_SECRET=change-me-in-production-use-openssl-rand-hex-32
ENVIRONMENT=development
PORT=8080

# PostgreSQL
POSTGRES_DSN=postgres://nla:nla_secret@postgres:5432/nla?sslmode=disable

# MongoDB
MONGO_URI=mongodb://mongo:27017
MONGO_DB=nla

# Redis
REDIS_ADDR=redis:6379
REDIS_PASSWORD=
REDIS_DB=0

# OpenAI — required
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.1-2025-11-13
OPENAI_PROXY=
OPENAI_TIMEOUT=200
